{
    "version": "0.2",
    "language": "en",
    "useGitignore": true,
    "ignorePaths": [
        ".git/**",
        ".vscode/**",
        "build/**",
        "cspell.json",
        "dist/**",
        "htmlcov/**",
        "resume.4ct",
        "resume.4tc",
        "resume.aux",
        "resume.css",
        "resume.dvi",
        "resume.html",
        "resume.idv",
        "resume.lg",
        "resume.tmp",
        "resume.xref"
    ],
    "ignoreRegExpList": ["color: .*"],
    "words": [
        "biber",
        "bibtex",
        "Blinn",
        "chktex",
        "cspell",
        "documentclass",
        "getline",
        "ghostscript",
        "Gitlytics",
        "headshot",
        "latexmk",
        "latexpand",
        "luatex",
        "make4ht",
        "markdownlint",
        "Matplotlib",
        "nonstopmode",
        "pandoc",
        "pdfinfo",
        "pipefail",
        "poppler",
        "postcheck",
        "precheck",
        "ryancswallace",
        "seccomp",
        "shellcheck",
        "TEXINPUTS",
        "texlive",
        "xetex"
    ]
}
